#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
UI_BINARY="${SCRIPT_DIR}/bin/rcc-ui"

source "${SCRIPT_DIR}/lib/core/common.sh"
source "${SCRIPT_DIR}/lib/core/commands.sh"

main() {
case "${1:-""}" in
		"")
			if [[ -x "$UI_BINARY" ]] && [[ -t 0 || -t 1 ]]; then
				"$UI_BINARY"
			else
				show_brand_banner
				interactive_main_menu
			fi
			;;
		"ssh")     exec "${SCRIPT_DIR}/bin/ssh.sh" "${@:2}" ;;
		"git")     exec "${SCRIPT_DIR}/bin/git.sh" "${@:2}" ;;
		"upgrade") exec "${SCRIPT_DIR}/bin/upgrade.sh" "${@:2}" ;;
		"apps")    exec "${SCRIPT_DIR}/bin/apps.sh" "${@:2}" ;;
		"ports")   exec "${SCRIPT_DIR}/bin/ports.sh" "${@:2}" ;;
		"battery") exec "${SCRIPT_DIR}/bin/battery.sh" "${@:2}" ;;
		"backup")  exec "${SCRIPT_DIR}/bin/backup.sh" "${@:2}" ;;
		"env")     exec "${SCRIPT_DIR}/bin/env.sh" "${@:2}" ;;
		"audit")
			case "${2:-}" in
				"fix")   exec "${SCRIPT_DIR}/bin/audit.sh" --fix "${@:3}" ;;
				"deep")  exec "${SCRIPT_DIR}/bin/audit.sh" --deep "${@:3}" ;;
				"quiet") exec "${SCRIPT_DIR}/bin/audit.sh" --deep --quiet "${@:3}" ;;
				"json")  exec "${SCRIPT_DIR}/bin/audit.sh" --deep --json "${@:3}" ;;
				"history") exec "${SCRIPT_DIR}/bin/audit.sh" --history "${@:3}" ;;
				"watch") exec "${SCRIPT_DIR}/bin/audit.sh" --watch "${@:3}" ;;
				*)       exec "${SCRIPT_DIR}/bin/audit.sh" "${@:2}" ;;
			esac
			;;
		"network") exec "${SCRIPT_DIR}/bin/network.sh" "${@:2}" ;;
		"wifi")    exec "${SCRIPT_DIR}/bin/wifi.sh" "${@:2}" ;;
		"disk")    exec "${SCRIPT_DIR}/bin/disk.sh" "${@:2}" ;;
		"memory")  exec "${SCRIPT_DIR}/bin/memory.sh" "${@:2}" ;;
		"startup")
			case "${2:-}" in
				"clean") exec "${SCRIPT_DIR}/bin/startup.sh" --clean "${@:3}" ;;
				*)       exec "${SCRIPT_DIR}/bin/startup.sh" "${@:2}" ;;
			esac
			;;
		"trash")   exec "${SCRIPT_DIR}/bin/trash.sh" "${@:2}" ;;
		"fonts")   exec "${SCRIPT_DIR}/bin/fonts.sh" "${@:2}" ;;
		"history") exec "${SCRIPT_DIR}/bin/history.sh" "${@:2}" ;;
		"certs")   exec "${SCRIPT_DIR}/bin/certs.sh" "${@:2}" ;;
		"docker")  exec "${SCRIPT_DIR}/bin/docker.sh" "${@:2}" ;;
		"xcode")   exec "${SCRIPT_DIR}/bin/xcode.sh" "${@:2}" ;;
		"completion")
			case "${2:-bash}" in
				bash) cat "${SCRIPT_DIR}/completions/bash/rcc" ;;
				zsh)  cat "${SCRIPT_DIR}/completions/zsh/_rcc" ;;
				*)    echo "Usage: rcc completion bash|zsh"; exit 1 ;;
			esac
			;;
		"--version"|"-V") show_version ;;
		"help"|"--help"|"-h") show_help ;;
		*) echo "Unknown command: $1"; show_help; exit 1 ;;
	esac
}

main "$@"
