#!/bin/bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
source "${SCRIPT_DIR}/lib/core/common.sh"
source "${SCRIPT_DIR}/lib/core/commands.sh"

main() {
case "${1:-""}" in
		"")
			interactive_main_menu
			;;
		"upgrade") exec "${SCRIPT_DIR}/bin/upgrade.sh" "${@:2}" ;;
		"audit")     exec "${SCRIPT_DIR}/bin/audit.sh" "${@:2}" ;;
		"audit deep"|"audit-deep") exec "${SCRIPT_DIR}/bin/audit.sh" --deep "${@:2}" ;;
		"audit quiet"|"audit-quiet") exec "${SCRIPT_DIR}/bin/audit.sh" --deep --quiet "${@:2}" ;;
		"audit fix"|"audit-fix") exec "${SCRIPT_DIR}/bin/audit.sh" --deep --fix "${@:2}" ;;
		"audit json"|"audit-json") exec "${SCRIPT_DIR}/bin/audit.sh" --deep --json "${@:2}" ;;
		"audit history"|"audit-history") exec "${SCRIPT_DIR}/bin/audit.sh" --history "${@:2}" ;;
		"audit watch"|"audit-watch") exec "${SCRIPT_DIR}/bin/audit.sh" --watch "${@:2}" ;;
		"network") exec "${SCRIPT_DIR}/bin/network.sh" "${@:2}" ;;
		"disk")    exec "${SCRIPT_DIR}/bin/disk.sh" "${@:2}" ;;
		"memory")  exec "${SCRIPT_DIR}/bin/memory.sh" "${@:2}" ;;
		"ssh")     exec "${SCRIPT_DIR}/bin/ssh.sh" "${@:2}" ;;
		"git")     exec "${SCRIPT_DIR}/bin/git.sh" "${@:2}" ;;
		"ports")   exec "${SCRIPT_DIR}/bin/ports.sh" "${@:2}" ;;
		"battery") exec "${SCRIPT_DIR}/bin/battery.sh" "${@:2}" ;;
		"backup")  exec "${SCRIPT_DIR}/bin/backup.sh" "${@:2}" ;;
		"env")     exec "${SCRIPT_DIR}/bin/env.sh" "${@:2}" ;;
		"startup") exec "${SCRIPT_DIR}/bin/startup.sh" "${@:2}" ;;
		"trash")   exec "${SCRIPT_DIR}/bin/trash.sh" "${@:2}" ;;
		"fonts")   exec "${SCRIPT_DIR}/bin/fonts.sh" "${@:2}" ;;
		"history") exec "${SCRIPT_DIR}/bin/history.sh" "${@:2}" ;;
		"certs")   exec "${SCRIPT_DIR}/bin/certs.sh" "${@:2}" ;;
		"docker") exec "${SCRIPT_DIR}/bin/docker.sh" "${@:2}" ;;
		"xcode")  exec "${SCRIPT_DIR}/bin/xcode.sh" "${@:2}" ;;
		"--version"|"-V") show_version ;;
		"list"|"commands") show_commands ;;
		"help"|"--help"|"-h") show_help ;;
		*) echo "Unknown command: $1"; show_help; exit 1 ;;
	esac
}

main "$@"