#compdef rcc
# shellcheck shell=zsh

# shellcheck disable=SC2154
(( $+functions[_rcc_audit_opts] )) ||
_rcc_audit_opts() {
  # shellcheck disable=SC2034
  local -a opts=(
    '--deep:full security audit (requires sudo)'
    '--fix:auto-fix issues where possible'
    '--dry-run:show fixes without applying'
    '--force:apply fixes without confirmation'
    '--quiet:suppress non-essential output'
    '--report:save report to file'
    '--json:JSON format'
    '--csv:CSV format'
    '--html:HTML report'
    '--md:client-ready Markdown report'
    '--rtf:client-ready RTF report'
    '--explain:plain-language notes on issues'
    '--remediation:client-facing intervention report'
    '--baseline:save current state as reference baseline'
    '--baseline-diff:compare current state against baseline'
    '--baseline-reset:remove the saved baseline'
    '--schedule:schedule a deep audit (daily|weekly|monthly|status|remove)'
    '--profile:load a client profile'
    '--profile-save:save current state as a client profile'
    '--profile-list:list saved profiles'
    '--profile-delete:remove a client profile'
    '--share:publish report as an anonymous GitHub Gist'
    '--sheet:generate an intervention sheet'
    '--hours:hours worked (intervention sheet)'
    '--notes:extra notes (intervention sheet)'
    '--history:show previous audit runs'
    '--diff:compare with previous run'
    '--watch:schedule weekly auto-audit'
    '--alert:alert on new issues'
    '--notify:send notification on issues'
  )
  _describe 'audit options' opts
}

_rcc() {
  local curcontext="$curcontext" state line
  # shellcheck disable=SC2034
  typeset -A opt_args

  _arguments -C \
    '--version[print version]' \
    '-V[print version]' \
    '--help[show help]' \
    '-h[show help]' \
    '1: :->command' \
    '*:: :->args'

  case "$state" in
    command)
      # shellcheck disable=SC2034
      local -a commands=(
        'upgrade:update package managers'
        'apps:update GUI apps (App Store + casks)'
        'audit:security audit'
        'network:network interfaces and info'
        'wifi:Wi-Fi networks and saved passwords'
        'fleet:audit multiple Macs over SSH'
        'disk:disk space and health'
        'memory:process memory usage'
        'ports:open ports and listeners'
        'battery:battery health and cycles'
        'backup:Time Machine status'
        'env:shell environment'
        'startup:launch agents and login items'
        'trash:trash contents'
        'fonts:font duplicates'
        'history:shell history analysis'
        'certs:SSL certificates'
        'docker:Docker status'
        'xcode:Xcode simulators'
        'ssh:SSH key management'
        'git:Git workflow helpers'
        'help:show help'
      )
      _describe 'command' commands
      ;;
    args)
      # shellcheck disable=SC1087,SC2195
      case "$line[1]" in
        audit)  _rcc_audit_opts ;;
        upgrade|apps) _arguments '--dry-run[show what would be upgraded]' '-n[show what would be upgraded]' ;;
        wifi)   _arguments '--active[active connection]' '--known[saved networks]' '--passwords[reveal Keychain passwords]' '--json[JSON format]' ;;
        disk)   _arguments '--large[find biggest files]' '--min[minimum file size]' '--top[how many to show]' '--json[JSON format]' ;;
        fleet)  _values 'fleet command' audit status add remove list '--hosts[hosts file]' '--parallel[max connections]' '--report[aggregate report]' '--json[JSON format]' '--explain[plain-language notes]' ;;
      esac
      ;;
  esac
}

_rcc "$@"
